// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Plan-Based Feature Access ──────────────────────────────

enum Feature {
  // Basic Module — Gate Management
  VISITOR_MANAGEMENT
  DELIVERY_MANAGEMENT
  DAILY_HELP_MANAGEMENT
  VEHICLE_MANAGEMENT
  KIDS_CHECKOUT
  DIRECTORY
  OVERSTAY_ALERT
  ATTENDANCE_MARKING
  PRE_APPROVE_ENTRY
  EMERGENCY_CALLING

  // Prime Module — Communications
  HELPDESK
  AMENITY_BOOKING
  COMMUNICATION
  HOME_PLANNER
  RENT_A_PARKING
  SOS_ALERT
  E_INTERCOM
  VEHICLE_SEARCH
  NOTICE_BOARD
  DOCUMENTS_UPLOADING
  SURVEYS
  ELECTION_POLLS
  MEETING_ALIGNMENT

  // Elite Module — Accounting
  GUARD_PATROLLING
  INVOICE_GENERATION
  UTILITY_PAYMENT
  RENT_PAYMENT
  INCOME_EXPENSE_ANALYSIS
  ASSET_INVENTORY_MANAGEMENT
  FINANCIAL_REPORTS
  FLATWISE_DUES
  BUDGET_MAINTENANCE
  RECEIPT_GENERATION
  BANK_RECONCILIATION
  MIS_REPORTS
  SECURITY_DEPOSIT
  BALANCE_SHEET_TAX
}

model Plan {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  features    Feature[]
  price       Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  communities Community[]
}

model SuperAdmin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ────────────────────────────────────────────────────────────

model Community {
  id               String                  @id @default(uuid())
  name             String                  @unique
  description      String?
  address          String?
  overstayLimits   Json?
  planId           String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  noOfBlocks       Int?
  noOfUnits        Int?
  plan             Plan?                   @relation(fields: [planId], references: [id], onDelete: SetNull)
  blocks           Block[]
  units            Unit[]
  announcements    Announcement[]
  bookings         Booking[]
  actualFacilities Facility[]              @relation("CommunityFacilities")
  facilityConfigs  FacilityConfiguration[] @relation("FacilityConfigs")
  tickets          Ticket[]
  users            User[]
  visitors         Visitor[]
  kidPasses        KidPass[]
  payments         Payment[]
  packages         Packages[]
  pdfs             Pdfs[]
  notices          Notice[]
  surveys          Survey[]
  polls            Poll[]
  vehicleRegistrations Vehicle[]
  parkingSpots     ParkingSpot[]
  parkingBookings  ParkingBooking[]
  meetings         Meeting[]
  homePlannerTasks HomePlannerTask[]
  emergencyAlerts  EmergencyAlert[]
}

model Block {
  id          String    @id @default(uuid())
  name        String
  communityId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  units       Unit[]

  @@index([communityId])
  @@index([communityId, name])
}

model Unit {
  id        String   @id @default(uuid())
  number    String
  blockId   String
  communityId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  block     Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  residents User[]

  @@index([blockId])
  @@index([communityId])
  @@index([communityId, number])
}

model User {
  id          String     @id @default(uuid())
  name        String
  email       String     @unique
  password    String
  role        UserRole   @default(RESIDENT)
  status      UserStatus @default(PENDING)
  communityId String
  unitId      String?
  phone       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  pushToken   String?
  bookings    Booking[]
  comments    Comment[]
  tickets     Ticket[]
  payments    Payment[]
  community           Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  unit                Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  visitors            Visitor[]        @relation("UserVisitors")
  kidPasses           KidPass[]        @relation("UserKidPasses")
  packages            Packages[]
  surveyResponses     SurveyResponse[]
  pollVotes           PollVote[]
  vehicleRegistrations Vehicle[]
  parkingBookings     ParkingBooking[]
  meetingRsvps        MeetingRsvp[]
  homePlannerTasks    HomePlannerTask[]
  emergencyAlerts     EmergencyAlert[]

  @@index([communityId])
  @@index([communityId, role])
  @@index([communityId, status])
  @@index([unitId])
}

model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String
  communityId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([communityId, createdAt])
}

model Visitor {
  id          String    @id @default(uuid())
  name        String
  contact     String
  vehicleNo   String?
  visitorType VisitorType @default(GUEST)
  visitDate   DateTime
  checkInAt   DateTime?
  checkOutAt  DateTime?
  userId      String?
  communityId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation("UserVisitors", fields: [userId], references: [id], onDelete: SetNull)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([communityId, visitDate])
  @@index([userId])
  @@index([contact])
  @@index([vehicleNo])
}

model KidPass {
  id          String    @id @default(uuid())
  childName   String
  childAge    Int?
  parentName  String
  contact     String
  permissions String    // Description of permissions/restrictions
  validFrom   DateTime
  validTo     DateTime
  checkInAt   DateTime?
  checkOutAt  DateTime?
  status      KidPassStatus @default(PENDING)
  userId      String
  communityId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation("UserKidPasses", fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([communityId, validFrom])
  @@index([userId])
  @@index([status])
}

model Ticket {
  id          String       @id @default(uuid())
  title       String
  category    String
  description String?
  status      TicketStatus @default(SUBMITTED)
  priority    TicketPriority @default(LOW)
  userId      String
  communityId String
  comments    Comment[]
  history     TicketHistory[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([userId])
  @@index([communityId, status])
  @@index([communityId, priority])
  @@index([communityId, category])
  @@index([createdAt])
}

model TicketHistory {
  id        String       @id @default(uuid())
  status    TicketStatus
  ticketId  String
  changedAt DateTime     @default(now())
  ticket    Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([ticketId, changedAt])
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  ticketId  String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([userId])
  @@index([ticketId, createdAt])
}

model FacilityConfiguration {
  id             String       @id @default(uuid())
  facilityType   FacilityType
  enabled        Boolean      @default(false)
  quantity       Int          @default(1)
  maxCapacity    Int          @default(10)
  isPaid         Boolean      @default(false)
  price          Float?       @default(0)
  priceType      PriceType?   @default(PER_HOUR)
  operatingHours String?      @default("09:00-21:00")
  rules          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  communityId    String
  facilities     Facility[]
  community      Community    @relation("FacilityConfigs", fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, facilityType])
}

model Facility {
  id              String                 @id @default(uuid())
  name            String
  open            String
  close           String
  slotMins        Int
  capacity        Int                    @default(10)
  communityId     String
  configurationId String?
  createdAt       DateTime               @default(now())
  facilityType    FacilityType
  updatedAt       DateTime               @updatedAt
  bookings        Booking[]
  community       Community              @relation("CommunityFacilities", fields: [communityId], references: [id], onDelete: Cascade)
  configuration   FacilityConfiguration? @relation(fields: [configurationId], references: [id])

  @@index([communityId])
  @@index([communityId, facilityType])
  @@index([configurationId])
}

model Booking {
  id          String        @id @default(uuid())
  startsAt    DateTime
  endsAt      DateTime
  note        String?
  status      BookingStatus @default(CONFIRMED)
  userId      String
  facilityId  String
  peopleCount Int           @default(1)
  communityId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  facility    Facility      @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id])

  @@index([facilityId, startsAt])
  @@index([communityId, startsAt])
  @@index([userId])
  @@index([communityId, status])
  @@index([startsAt, endsAt])
}

model Payment {
  id          String        @id @default(uuid())
  amount      Float
  currency    String        @default("INR")
  description String
  method      String?
  status      PaymentStatus @default(PENDING)
  dueDate     DateTime?
  paidAt      DateTime?
  userId      String
  communityId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([communityId])
  @@index([communityId, status])
  @@index([status, dueDate])
  @@index([createdAt])
}

model Packages {
  id          String          @id @default(uuid())
  name        String
  userId      String
  communityId String
  image       String
  status      PackageStatus   @default(PENDING)
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
}

model Pdfs {
  id          String     @id @default(uuid())
  name        String
  content     Bytes      
  communityId String
  community   Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
}


enum UserRole {
  RESIDENT
  ADMIN
  GATEKEEPER
  STAFF
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  SUBMITTED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum VisitorType {
  GUEST
  DELIVERY
  CAB_AUTO
}

enum PriceType {
  PER_HOUR
  PER_DAY
  PER_WEEK
  PER_MONTH
  ONE_TIME
}

enum FacilityType {
  SWIMMING_POOL
  GYMNASIUM
  TENNIS_COURT
  BASKETBALL_COURT
  PLAYGROUND
  CLUBHOUSE
  PARTY_HALL
  CONFERENCE_ROOM
  LIBRARY
  GARDEN
  JOGGING_TRACK
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  OVERDUE
}

enum PackageStatus {
  PENDING
  PICKED
}

enum KidPassStatus {
  PENDING
  APPROVED
  REJECTED
  CHECKED_IN
  CHECKED_OUT
}

enum VehicleType {
  CAR
  BIKE
  TRUCK
  SUV
  VAN
  OTHER
}

enum VehicleStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Vehicle Management ─────────────────────────────────────

model Vehicle {
  id              String        @id @default(uuid())
  plateNumber     String
  vehicleType     VehicleType   @default(CAR)
  brand           String?
  model           String?
  color           String?
  status          VehicleStatus @default(PENDING)
  rejectionReason String?
  userId          String
  communityId     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  community       Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([communityId, status])
  @@index([userId])
  @@index([plateNumber])
}

// ─── Notice Board ───────────────────────────────────────────

model Notice {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    String   @default("General")
  isPinned    Boolean  @default(false)
  communityId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([communityId, isPinned])
}

// ─── Surveys ────────────────────────────────────────────────

enum SurveyQuestionType {
  MULTIPLE_CHOICE
  YES_NO
  RATING
  TEXT
}

model Survey {
  id          String           @id @default(uuid())
  title       String
  description String?
  startDate   DateTime         @default(now())
  endDate     DateTime
  communityId String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  community   Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  questions   SurveyQuestion[]
  responses   SurveyResponse[]

  @@index([communityId])
}

model SurveyQuestion {
  id       String             @id @default(uuid())
  question String
  type     SurveyQuestionType
  options  Json?
  surveyId String
  survey   Survey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
}

model SurveyResponse {
  id        String   @id @default(uuid())
  surveyId  String
  userId    String
  answers   Json
  createdAt DateTime @default(now())
  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
  @@index([surveyId])
  @@index([userId])
}

// ─── Election / Polls ───────────────────────────────────────

model Poll {
  id          String          @id @default(uuid())
  title       String
  description String?
  startDate   DateTime        @default(now())
  endDate     DateTime
  communityId String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  community   Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  candidates  PollCandidate[]
  votes       PollVote[]

  @@index([communityId])
}

model PollCandidate {
  id          String     @id @default(uuid())
  name        String
  description String?
  pollId      String
  poll        Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes       PollVote[]

  @@index([pollId])
}

model PollVote {
  id          String        @id @default(uuid())
  pollId      String
  candidateId String
  userId      String
  createdAt   DateTime      @default(now())
  poll        Poll          @relation(fields: [pollId], references: [id], onDelete: Cascade)
  candidate   PollCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId])
  @@index([candidateId])
  @@index([userId])
}

// ─── Parking ─────────────────────────────────────────────────

enum SpotType {
  TWO_WHEELER
  FOUR_WHEELER
  EV
}

enum ParkingBookingStatus {
  ACTIVE
  CANCELLED
}

model ParkingSpot {
  id          String           @id @default(uuid())
  spotNumber  String
  spotType    SpotType
  floor       String?
  block       String?
  pricePerDay Float
  isAvailable Boolean          @default(true)
  communityId String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  community   Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  bookings    ParkingBooking[]

  @@index([communityId])
  @@index([communityId, isAvailable])
}

model ParkingBooking {
  id          String               @id @default(uuid())
  spotId      String
  userId      String
  communityId String
  fromDate    DateTime
  toDate      DateTime
  status      ParkingBookingStatus @default(ACTIVE)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  spot        ParkingSpot          @relation(fields: [spotId], references: [id], onDelete: Cascade)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community            @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([userId])
  @@index([spotId])
}

// ─── Meetings ────────────────────────────────────────────────

enum RsvpResponse {
  GOING
  NOT_GOING
  MAYBE
}

model Meeting {
  id          String        @id @default(uuid())
  title       String
  description String?
  location    String?
  scheduledAt DateTime
  agenda      String[]
  communityId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  rsvps       MeetingRsvp[]

  @@index([communityId])
  @@index([communityId, scheduledAt])
}

model MeetingRsvp {
  id        String       @id @default(uuid())
  meetingId String
  userId    String
  response  RsvpResponse
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  meeting   Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

// ─── Home Planner ────────────────────────────────────────────

enum TaskType {
  MAINTENANCE
  CONTRACTOR
  SERVICE
  CLEANING
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

model HomePlannerTask {
  id            String     @id @default(uuid())
  title         String
  description   String?
  type          TaskType
  status        TaskStatus @default(PENDING)
  scheduledDate DateTime?
  userId        String
  communityId   String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  community     Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([communityId])
  @@index([userId, communityId])
}

// ─── Emergency / SOS ─────────────────────────────────────────

enum AlertStatus {
  ACTIVE
  CANCELLED
  RESOLVED
}

model EmergencyAlert {
  id          String      @id @default(uuid())
  userId      String
  communityId String
  name        String
  unitNumber  String?
  blockName   String?
  status      AlertStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  cancelledAt DateTime?
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([communityId])
  @@index([communityId, status])
}
